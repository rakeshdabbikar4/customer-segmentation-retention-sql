</sql><sql name="01_data_cleaning.sql" filename="C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/01_data_cleaning.sql">-- Reference to file &quot;C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/01_data_cleaning.sql&quot; (not supported by this version) --</sql><sql name="Cleaned data">SELECT COUNT(*) FROM retail_clean;</sql><sql name="Customer Total Spend">SELECT CustomerID,SUM(Quantity * UnitPrice) AS total_spent
FROM retail_clean
GROUP BY CustomerID
ORDER BY total_spent DESC
LIMIT 10;</sql><sql name="Customer Segmentation">SELECT 
    CustomerID,
    SUM(Quantity * UnitPrice) AS total_spent,
    CASE 
        WHEN SUM(Quantity * UnitPrice) &gt; 5000 THEN 'High Value'
        WHEN SUM(Quantity * UnitPrice) &gt; 2000 THEN 'Medium Value'
        ELSE 'Low Value'
    END AS customer_segment
FROM retail_clean
GROUP BY CustomerID;</sql><sql name="02_monthly_revenue.sql" filename="C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/02_monthly_revenue.sql">-- Reference to file &quot;C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/02_monthly_revenue.sql&quot; (not supported by this version) --</sql><sql name="03_top_customers.sql" filename="C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/03_top_customers.sql">-- Reference to file &quot;C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/03_top_customers.sql&quot; (not supported by this version) --</sql><sql name="04_country_analysis.sql" filename="C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/04_country_analysis.sql">-- Reference to file &quot;C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/04_country_analysis.sql&quot; (not supported by this version) --</sql><sql name="05_top_revenue_products.sql" filename="C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/05_top_revenue_products.sql">-- Reference to file &quot;C:/Users/Dabbikar Rakesh/OneDrive/Documents/OneDrive2/OneDrive/projects/ecommerce-sql-analysis/05_top_revenue_products.sql&quot; (not supported by this version) --</sql><current_tab id="8"/></tab_sql></sqlb_project>
